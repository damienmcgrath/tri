exports[`buildSessionVerdictPrompt sample 4 (CSS swim): orders the three concerns by severity desc 1`] = `
"intent:
  type: css_swim
  structure: intervals
  source: athlete_described

athlete:
  css: 95 /100m
  hr_max: 180 bpm

findings:
[1] id=F1 (intensity-compliance v1.0.0)
  category=execution polarity=concern severity=3 scope=session
  headline: CSS reps held 3 sec/100m under target
  reasoning: All eight CSS reps averaged 98 sec/100m against a 95 target.
  evidence:
    - avg_rep_pace_per_100m=98 sec/100m
    - css_target=95 sec/100m [ref: css]
  prescription: NEXT CSS swim: hold 95 sec/100m on the first four reps; ease only on rep 5+. (target: rep_pace=95) [confidence: high]
[2] id=F2 (stroke-economy v1.0.0)
  category=technique polarity=concern severity=2 scope=session
  headline: SWOLF rose into mid-40s by rep 6
  reasoning: Stroke count climbed 4 strokes per length over the set.
  evidence:
    - swolf_rep1=38
    - swolf_rep8=42
  prescription: (none)
[3] id=F3 (interval-recovery v1.0.0)
  category=pacing polarity=concern severity=2 scope=session
  headline: Rest intervals overran by 8 sec on average
  reasoning: Recovery extended from 15 sec planned to 23 sec actual.
  evidence:
    - rest_drift_sec=8 sec
    - planned_rest_sec=15 sec
  prescription: (none)"
`;

