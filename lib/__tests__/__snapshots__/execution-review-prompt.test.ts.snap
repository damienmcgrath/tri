// Jest Snapshot v1, https://jestjs.io/docs/snapshot-testing

exports[`buildSessionVerdictPrompt sample 1 (threshold bike): every numeric claim in the user payload exists in a finding.evidence entry 1`] = `
"intent:
  type: threshold_bike
  structure: intervals
  source: plan

athlete:
  ftp: 245 W
  hr_max: 188 bpm
  weight: 72 kg

findings:
[1] id=F1 (intensity-compliance v1.0.0)
  category=execution polarity=concern severity=3 scope=session
  headline: Intervals ran 5 W under target on average
  reasoning: All four work intervals averaged 240 W against a 245 W FTP target.
  evidence:
    - avg_interval_power=240 W
    - target_power=245 W [ref: ftp]
    - normalized_power=238 W
    - intensity_factor=0.97
  prescription: NEXT threshold bike: hold 245 W on the first two intervals before easing. (target: interval_power=245) [confidence: high]
[2] id=F2 (decoupling v1.1.0)
  category=durability polarity=observation severity=1 scope=session
  headline: Mild HR drift across halves
  reasoning: HR/power ratio drifted 4.2% from first half to second half.
  evidence:
    - decoupling_pct=4.2 %
    - hr_first_half=152 bpm
    - hr_second_half=158 bpm
  prescription: (none)
[3] id=F4 (completion v1.0.0)
  category=execution polarity=positive severity=1 scope=session
  headline: Completed all four intervals
  reasoning: Session structure executed in full.
  evidence:
    - completion_ratio=1
    - intervals_completed=4
    - intervals_planned=4
  prescription: (none)
[4] id=F3 (tss v1.0.0)
  category=durability polarity=observation severity=1 scope=session
  headline: TSS 78 — moderate threshold load
  reasoning: 62-minute threshold session contributed 78 TSS.
  evidence:
    - tss=78
    - duration_min=62 min
  prescription: (none)"
`;

exports[`buildSessionVerdictPrompt sample 2 (long run): renders prescriptive text from highest-severity finding 1`] = `
"intent:
  type: long_run
  structure: steady
  source: plan

athlete:
  threshold_pace: 248 sec/km
  hr_max: 192 bpm
  weight: 68 kg

findings:
[1] id=F1 (intent-match v1.0.0)
  category=execution polarity=concern severity=2 scope=session
  headline: Drifted out of zone 2 in the back half
  reasoning: Average HR 162 bpm exceeded the 155 bpm zone-2 ceiling for the final 35 minutes.
  evidence:
    - intent_match=0.62
    - avg_hr=162 bpm
    - z2_ceiling=155 bpm [ref: lthr]
  prescription: NEXT long run: cap HR at 155 bpm; walk 30 sec at every km if it climbs. (target: hr_ceiling=155) [confidence: high]
[2] id=F3 (tss v1.0.0)
  category=durability polarity=observation severity=1 scope=session
  headline: TSS 92 — long aerobic load
  reasoning: Two-hour aerobic effort contributed 92 TSS.
  evidence:
    - tss=92
    - duration_min=118 min
  prescription: (none)
[3] id=F2 (completion v1.0.0)
  category=execution polarity=positive severity=0 scope=session
  headline: Hit the planned distance
  reasoning: Ran 21.0 km against a 20.0 km plan.
  evidence:
    - completion_ratio=1.05
    - distance_actual_km=21 km
    - distance_planned_km=20 km
  prescription: (none)"
`;

